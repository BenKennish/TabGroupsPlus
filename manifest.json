{
    "manifest_version": 3,
    "name": "Tab Groups Plus",
    "short_name": "Tab Groups +",
    "version": "1.6.0",
    "description": "Auto-collapses inactive tab groups, aligns the active tab group, and adds new tabs to the currently active tab's group",
    "author": "ben@kennish.net",
    "homepage_url": "https://github.com/BenKennish/TabGroupsPlus",
    "icons": {
        "128": "images/icon-128.png"
    },
    "permissions": [
        "tabGroups", // Warning displayed: "View and manage your tab groups."
        "storage", // No warning displayed
        "tabs" // Warning displayed: "Read your browsing history.".  Allows using properties: url, pendingUrl, title, and favIconUrl.
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        }
    ],
    //"host_permissions" - would allow us to inject content scripts in dynamically (and see https://developer.chrome.com/docs/extensions/develop/concepts/declare-permissions#host-permissions)
    "options_page": "options.html",
    /*
    "options_ui": {
        "page": "options.html",
        "open_in_tab": false
    },
    */
    "action": {
        "default_title": "Tab Groups Plus",
        "default_icon": {
            //"16": "images/icon16.png",
            //"24": "images/icon24.png",
            //"32": "images/icon32.png"
        },
        "default_popup": "options.html"
    },
    "incognito": "split",
    "minimum_chrome_version": "89"
}